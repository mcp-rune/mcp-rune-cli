# Token used by the framework's CRUD tools when calling your API backend.
# For local dev without a real backend, any non-empty value works.
ACCESS_TOKEN=demo-token

# GitHub Packages read token (used by .npmrc to install @mcp-rune/mcp-rune).
# Create one at: https://github.com/settings/tokens (classic; scope: read:packages).
GH_PACKAGES_READ_TOKEN=
