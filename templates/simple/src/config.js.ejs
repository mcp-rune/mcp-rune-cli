import { createServer } from '@mcp-rune/mcp-rune/server';
import { DATA_TOOL_CLASSES } from '@mcp-rune/mcp-rune/tools';
import { STRATEGY_TOOL_CLASSES } from '@mcp-rune/mcp-rune/prompts';
import { MODEL_CLASSES } from './models/index.js';
import { promptRegistry } from './prompts/index.js';

const serverContext = {
  name: '<%= projectNamePascal %>',
  namespace: '<%= projectName %>',
  description: 'MCP server scaffolded with @mcp-rune/create',
};

const toolRegistry = {
  serverContext,

  registerTools(mcpServer) {
    const deps = {
      logger: console,
      models: MODEL_CLASSES,
      promptRegistry,
      serverContext: this.serverContext,
    };

    for (const ToolClass of Object.values(DATA_TOOL_CLASSES)) {
      const tool = new ToolClass(deps);
      mcpServer.tool(
        tool.name,
        tool.baseDescription,
        tool.inputSchema,
        tool.annotations,
        async (args) => {
          tool.apiClient = {
            /* inject your API client here */
          };
          return tool.execute(args);
        },
      );
    }

    for (const ToolClass of Object.values(STRATEGY_TOOL_CLASSES)) {
      const tool = new ToolClass(deps);
      mcpServer.tool(
        tool.name,
        tool.baseDescription,
        tool.inputSchema,
        tool.annotations,
        async (args) => tool.execute(args),
      );
    }
  },
};

export const mcpConfig = {
  name: '<%= projectName %>',

  createServer({ sessionId, transport, getAccessToken }) {
    return createServer({
      name: '<%= projectName %>',
      version: '0.1.0',
      sessionId,
      transport,
      toolRegistry,
      promptRegistry,
      getAccessToken,
    });
  },
};
