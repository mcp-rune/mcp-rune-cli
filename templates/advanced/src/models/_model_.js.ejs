import { BaseModel } from '@mcp-rune/mcp-rune/core';

export class <%= model.namePascal %> extends BaseModel {
  static description = '<%= model.description || `A ${model.name} record` %>';
  static api = { endpoint: '<%= model.endpoint || `${model.fileName}s` %>' };

  static attributes = {
<% for (const attr of model.attributes) { -%>
    <%= attr.name %>: {
      type: '<%= attr.type %>',
<% if (attr.required) { -%>
      required: true,
<% } -%>
<% if (attr.description) { -%>
      description: '<%= attr.description %>',
<% } -%>
    },
<% } -%>
  };

  static get attributesConfig() {
    return this.attributes;
  }
}
