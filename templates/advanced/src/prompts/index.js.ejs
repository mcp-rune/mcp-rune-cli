import { PromptRegistry } from './registry.js';
<% for (const m of models) { -%>
import { <%= m.namePascal %>Prompt } from './<%= m.fileName %>-prompt.js';
<% } -%>

const PROMPT_CLASSES = {
<% for (const m of models) { -%>
  create_<%= m.fileName %>: {
    promptClass: <%= m.namePascal %>Prompt,
    model: '<%= m.fileName %>',
    toolDocDescription: 'For creating <%= m.fileName %> records',
    required: false,
    recommendedForBulk: false,
  },
<% } -%>
};

export const promptRegistry = new PromptRegistry(PROMPT_CLASSES);
