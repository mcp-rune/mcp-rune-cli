{
  "name": "@mcp-rune/create",
  "version": "0.1.0",
  "description": "Scaffolder for mcp-rune-based MCP servers",
  "type": "module",
  "bin": {
    "rune": "./bin/rune.js",
    "create-mcp-rune": "./bin/rune.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "execa": "^9.5.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.12.4",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
